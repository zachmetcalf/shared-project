{
    "version": 3,
    "configurePresets": [
        {
            "name": "shared-project",
            "hidden": true,
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build",
            "installDir": "${sourceDir}/install",
            "toolchainFile": "${sourceDir}/../3rdparty/vcpkg/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "VCPKG_MANIFEST_DIR": "${sourceDir}/../shared",
                "BUILD_SHARED_TESTS": "ON",
                "BUILD_SHARED_DEMOS": "OFF"
            }
        },
        {
            "name": "windows",
            "inherits": "shared-project",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl",
                "CMAKE_CXX_COMPILER": "cl"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "linux",
            "inherits": "shared-project",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "windows-debug",
            "inherits": "windows",
            "binaryDir": "${sourceDir}/build/windows-debug",
            "installDir": "${sourceDir}/install/windows-debug",
            "cacheVariables": {
                "BINARY_DIRECTORY": "${sourceDir}/bin/windows-debug",
                "INSTALL_DIRECTORY": "${sourceDir}/install/windows-debug",
                "LOGGING_MIN_COMPILED_VERBOSITY": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "windows-release",
            "inherits": "windows",
            "binaryDir": "${sourceDir}/build/windows-release",
            "installDir": "${sourceDir}/install/windows-release",
            "cacheVariables": {
                "BINARY_DIRECTORY": "${sourceDir}/bin/windows-release",
                "INSTALL_DIRECTORY": "${sourceDir}/install/windows-release",
                "LOGGING_MIN_COMPILED_VERBOSITY": "Log"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "linux-debug",
            "inherits": "linux",
            "binaryDir": "${sourceDir}/build/linux-debug",
            "installDir": "${sourceDir}/install/linux-debug",
            "cacheVariables": {
                "BINARY_DIRECTORY": "${sourceDir}/bin/linux-debug",
                "INSTALL_DIRECTORY": "${sourceDir}/install/linux-debug",
                "LOGGING_MIN_COMPILED_VERBOSITY": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "linux-release",
            "inherits": "linux",
            "binaryDir": "${sourceDir}/build/linux-release",
            "installDir": "${sourceDir}/install/linux-release",
            "cacheVariables": {
                "BINARY_DIRECTORY": "${sourceDir}/bin/linux-release",
                "INSTALL_DIRECTORY": "${sourceDir}/install/linux-release",
                "LOGGING_MIN_COMPILED_VERBOSITY": "Log"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows-debug",
            "configurePreset": "windows-debug",
            "configuration": "Debug"
        },
        {
            "name": "windows-release",
            "configurePreset": "windows-release",
            "configuration": "Release"
        },
        {
            "name": "linux-debug",
            "configurePreset": "linux-debug",
            "configuration": "Debug"
        },
        {
            "name": "linux-release",
            "configurePreset": "linux-release",
            "configuration": "Release"
        }
    ]
}
