{
    "version": 3,
    "configurePresets": [
        {
            "name": "shared-project",
            "hidden": true,
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "installDir": "${sourceDir}/install/${presetName}",
            "toolchainFile": "${sourceDir}/../3rdparty/vcpkg/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "BINARY_DIRECTORY": "${sourceDir}/bin/${presetName}",
                "INSTALL_DIRECTORY": "${sourceDir}/install/${presetName}",
                "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "VCPKG_MANIFEST_DIR": "${sourceDir}/../shared",
                "BUILD_SHARED_TESTS": "OFF",
                "BUILD_SHARED_DEMOS": "OFF"
            }
        },
        {
            "name": "windows",
            "inherits": "shared-project",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl",
                "CMAKE_CXX_COMPILER": "cl"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "linux",
            "inherits": "shared-project",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "windows-debug",
            "inherits": "windows",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows-static-md",
                "DYNAMIC_LINK_SHARED": "OFF",
                "LOGGING_MIN_COMPILED_VERBOSITY": "Debug"
            }
        },
        {
            "name": "windows-monolithic-debug",
            "inherits": "windows-debug"
        },
        {
            "name": "windows-dynamic-debug",
            "inherits": "windows-debug",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows",
                "DYNAMIC_LINK_SHARED": "ON"
            }
        },
        {
            "name": "windows-release",
            "inherits": "windows-debug",
            "cacheVariables": {
                "LOGGING_MIN_COMPILED_VERBOSITY": "Log"
            }
        },
        {
            "name": "linux-debug",
            "inherits": "linux",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-linux",
                "DYNAMIC_LINK_SHARED": "OFF",
                "LOGGING_MIN_COMPILED_VERBOSITY": "Debug"
            }
        },
        {
            "name": "linux-monolithic-debug",
            "inherits": "linux-debug"
        },
        {
            "name": "linux-dynamic-debug",
            "inherits": "linux-debug",
            "cacheVariables": {
                "DYNAMIC_LINK_SHARED": "ON"
            }
        },
        {
            "name": "linux-release",
            "inherits": "linux-debug",
            "cacheVariables": {
                "LOGGING_MIN_COMPILED_VERBOSITY": "Log"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows-build",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "linux-build",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "windows-debug",
            "inherits": "windows-build",
            "configurePreset": "windows-debug",
            "configuration": "Debug"
        },
        {
            "name": "windows-monolithic-debug",
            "inherits": "windows-build",
            "configurePreset": "windows-monolithic-debug",
            "configuration": "Debug"
        },
        {
            "name": "windows-dynamic-debug",
            "inherits": "windows-build",
            "configurePreset": "windows-dynamic-debug",
            "configuration": "Debug"
        },
        {
            "name": "windows-release",
            "inherits": "windows-build",
            "configurePreset": "windows-release",
            "configuration": "Release"
        },
        {
            "name": "linux-debug",
            "inherits": "linux-build",
            "configurePreset": "linux-debug",
            "configuration": "Debug"
        },
        {
            "name": "linux-monolithic-debug",
            "inherits": "linux-build",
            "configurePreset": "linux-monolithic-debug",
            "configuration": "Debug"
        },
        {
            "name": "linux-dynamic-debug",
            "inherits": "linux-build",
            "configurePreset": "linux-dynamic-debug",
            "configuration": "Debug"
        },
        {
            "name": "linux-release",
            "inherits": "linux-build",
            "configurePreset": "linux-release",
            "configuration": "Release"
        }
    ]
}
